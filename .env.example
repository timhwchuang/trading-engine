# Copy to .env and fill in — never commit .env
# cp .env.example .env

# Shioaji API (required for live)
SJ_API_KEY=your_api_key_here
SJ_SEC_KEY=your_secret_key_here

# CA certificate (required for live / non-simulation)
SJ_CA_PATH=/path/to/your/Sinopac.pfx
SJ_CA_PASSWD=your_ca_password

# Optional: fallback when activate_ca needs person_id
# SJ_CA_PERSON_ID=